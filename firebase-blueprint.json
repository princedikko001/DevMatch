{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user role, skills, and other profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Student", "Mentor"] },
        "skills": { "type": "array", "items": { "type": "string" } },
        "level": { "type": "string", "enum": ["Beginner", "Intermediate", "Expert"] },
        "githubUrl": { "type": "string", "format": "uri" },
        "expertise": { "type": "string" },
        "maintainedProject": { "type": "string" },
        "totalHelpsGiven": { "type": "integer", "description": "Number of helpful feedbacks given" }
      },
      "required": ["uid", "email", "role"]
    },
    "HubPost": {
      "title": "Hub Post",
      "description": "A request for help or feedback in the Collaboration Hub.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorID": { "type": "string" },
        "authorName": { "type": "string" },
        "projectName": { "type": "string" },
        "content": { "type": "string" },
        "codeSnippet": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["Code Help", "General Feedback"] },
        "unanswered": { "type": "boolean" }
      },
      "required": ["authorID", "projectName", "content", "type", "timestamp"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A reply to a Hub Post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorID": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isAI": { "type": "boolean" }
      },
      "required": ["authorID", "content", "timestamp"]
    },
    "Project": {
      "title": "Project",
      "description": "Stores project details and tags.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "difficulty": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Global projects list"
    },
    "/hubPosts/{postId}": {
      "schema": "HubPost",
      "description": "Collaboration hub posts"
    },
    "/hubPosts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on hub posts"
    }
  }
}
